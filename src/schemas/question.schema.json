{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Question",
  "description": "A dinosaur quiz question",
  "type": "object",
  "properties": {
    "statement": {
      "description": "The question statement",
      "type": "string",
      "minLength": 1
    },
    "options": {
      "description": "The answer options",
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "correctIndex": {
      "description": "The index of the correct answer in the options array",
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "dinoId": {
      "description": "The identifier of the dinosaur related to the question",
      "type": "string",
      "minLength": 1
    },
    "funFact": {
      "description": "A fun fact about the dinosaur",
      "type": "string",
      "minLength": 1
    },
    "image": {
      "description": "The filename of the dinosaur image",
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["statement", "options", "correctIndex", "dinoId", "funFact", "image"],
  "additionalProperties": false
}