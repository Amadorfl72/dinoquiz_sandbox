[{"id":1,"dinosaur":"T-Rex","statement":"¿Qué significa el nombre 'Tyrannosaurus rex'?","options":["Rey lagarto tirano","Lagarto rápido","Lagarto con cuernos","Lagarto volador"],"correctAnswer":"Rey lagarto tirano","funFact":"El T-Rex tenía una mordida tan fuerte que podía romper huesos de otros dinosaurios.","imageReference":"trex.png"},{"id":2,"dinosaur":"T-Rex","statement":"¿Cuánto medía aproximadamente un T-Rex adulto?","options":["5 metros","10 metros","15 metros","20 metros"],"correctAnswer":"15 metros","funFact":"El T-Rex podía pesar hasta 9 toneladas, tanto como un elefante africano.","imageReference":"trex.png"},{"id":3,"dinosaur":"T-Rex","statement":"¿Qué comía principalmente el T-Rex?","options":["Plantas","Peces","Otros dinosaurios","Insectos"],"correctAnswer":"Otros dinosaurios","funFact":"El T-Rex tenía dientes del tamaño de plátanos para desgarrar la carne.","imageReference":"trex.png"},{"id":4,"dinosaur":"T-Rex","statement":"¿Cuántos dedos tenía el T-Rex en cada pata delantera?","options":["1","2","3","4"],"correctAnswer":"2","funFact":"Las patas delanteras del T-Rex eran pequeñas pero muy fuertes, con garras afiladas.","imageReference":"trex.png"},{"id":5,"dinosaur":"Triceratops","statement":"¿Cuántos cuernos tenía el Triceratops?","options":["1","2","3","4"],"correctAnswer":"3","funFact":"El Triceratops usaba sus cuernos para defenderse de depredadores como el T-Rex.","imageReference":"triceratops.png"},{"id":6,"dinosaur":"Triceratops","statement":"¿Para qué servía el gran collar óseo del Triceratops?","options":["Para volar","Para nadar","Para protegerse","Para atraer pareja"],"correctAnswer":"Para protegerse","funFact":"El collar óseo del Triceratops podía medir hasta 2 metros de ancho.","imageReference":"triceratops.png"},{"id":7,"dinosaur":"Triceratops","statement":"¿Qué tipo de dinosaurio era el Triceratops?","options":["Carnívoro","Herbívoro","Omnívoro","Insectívoro"],"correctAnswer":"Herbívoro","funFact":"El Triceratops vivía en manadas para