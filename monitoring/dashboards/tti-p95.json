{
  "dashboard": {
    "title": "TTI p95 Dashboard",
    "panels": [
      {
        "title": "TTI p95",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(tti_seconds_bucket[1m])) by (le))"
          }
        ]
      }
    ]
  }
}